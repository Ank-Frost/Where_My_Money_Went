{
  "name": "where-my-money-went-backend",
  "version": "1.0.0",
  "description": "Backend for Where My Money Went finance tracker",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
